{
  "$schema": "https://design-tokens.org/draft",
  "color": {
    "paper":      { "50": "#FBF7F0", "100": "#F5EFE3", "200": "#EDE4D1" },
    "line":       "#E9E1D3",
    "soil":       { "100": "#E7DDCB", "300": "#B49F7F", "500": "#6B553C", "700": "#3F2F1E", "900": "#2A1F14" },
    "evergreen":  { "50":  "#E8F1EC", "100": "#C9E0D1", "300": "#6FB28F", "500": "#2B8A61", "600": "#1F6F50", "700": "#185A40", "900": "#0D3A29" },
    "terracotta": { "50":  "#FBEFE7", "100": "#F5D9C6", "300": "#E19570", "500": "#C8552B", "600": "#A9441F", "700": "#853618" },
    "ink":        { "400": "#4E6E86", "600": "#2E4A5E", "900": "#162936" },
    "status": {
      "available":   { "fg": "#0F5A3A", "bg": "#E3F2E9", "base": "#1F8A5B" },
      "reserved":    { "fg": "#7A5309", "bg": "#FBEFD3", "base": "#C68A18" },
      "sold":        { "fg": "#7A2020", "bg": "#F7DCD9", "base": "#B23A3A" },
      "hold":        { "fg": "#2E3744", "bg": "#E4E7EB", "base": "#4A5568" }
    }
  },
  "font": {
    "sans":  "Plus Jakarta Sans",
    "hindi": "IBM Plex Sans Devanagari",
    "mono":  "JetBrains Mono"
  },
  "fontSize": {
    "xs": 12, "sm": 13, "base": 15, "md": 16, "lg": 18, "xl": 22, "2xl": 28, "3xl": 36, "4xl": 44
  },
  "lineHeight": { "tight": 1.15, "snug": 1.30, "base": 1.45, "relax": 1.60 },
  "fontWeight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
  "space":      { "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "8": 32, "10": 40, "14": 56, "18": 72 },
  "radius":     { "xs": 4, "sm": 6, "md": 10, "lg": 12, "xl": 16, "pill": 999 },
  "shadow": {
    "s1": { "color": "#2A1F14", "x": 0, "y": 1, "blur": 2,  "opacity": 0.06, "elevation": 1 },
    "s2": { "color": "#2A1F14", "x": 0, "y": 8, "blur": 16, "opacity": 0.18, "elevation": 6 },
    "s3": { "color": "#2A1F14", "x": 0, "y": 20,"blur": 32, "opacity": 0.28, "elevation": 12 }
  },
  "motion": {
    "duration": { "fast": 90, "base": 180, "slow": 320 },
    "easing":   { "out": [0.22, 1, 0.36, 1], "in": [0.42, 0, 1, 1], "standard": [0.20, 0, 0, 1] }
  },
  "layout": { "headerHeight": 56, "tabBarHeight": 64, "designWidth": 390 }
}
